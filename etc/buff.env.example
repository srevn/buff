# buff server configuration — environment overrides

# Storage root (the os.Root boundary for every clip)
#BUFF_DATA_DIR=/var/lib/buff

# Listen address
#BUFF_ADDR=:8080

# Caps (0 = unlimited). Sizes take a K/M/G/T suffix, all 1024-based: 1G == 1Gi == 1GiB
#BUFF_MAX_CLIP=1GiB
#BUFF_MAX_TOTAL=10GiB
#BUFF_MAX_CLIPS=10000

# Retention measured from finalize (0 = keep forever), and the reaper's tick.
#BUFF_TTL=24h
#BUFF_REAP_INTERVAL=60s

# Upload deadlines: a per-request idle timeout (must be > 0), and an absolute cap per upload (0 = off).
#BUFF_UPLOAD_IDLE=30s
#BUFF_UPLOAD_MAX=0

# Absolute cap on how long a waiting GET (--wait / --follow-next) parks before a 404 (0 = off).
# A park moves no bytes, so it has no idle deadline; this is its only server-owned duration bound.
#BUFF_WAIT_MAX=0

# Durability and integrity. FSYNC=off stays atomic but unflushed (faster; a power
# loss may lose recently finalized clips). CHECKSUM stores and verifies a CRC32C.
#BUFF_FSYNC=on
#BUFF_CHECKSUM=off
